{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": [
    "github-copilot"
  ],
  "share": "disabled",
  "model": "github-copilot/claude-opus-4.6",
  "permission": {
    "*": "allow",
    "bash": {
      "git push*": "deny",
      "az * create *": "deny",
      "az * delete *": "deny",
      "az * update *": "deny",
      "az * start *": "deny",
      "az * stop *": "deny",
      "az * restart *": "deny",
      "az * set-policy *": "deny",
      "az login*": "deny",
      "az logout*": "deny"
    }
  }
}