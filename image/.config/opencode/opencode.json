{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": [
    "github-copilot"
  ],
  "share": "disabled",
  "model": "github-copilot/claude-opus-4.6",
  "small_model": "github-copilot/gpt-5.4-mini",
  "permission": {
    "*": "allow",
    "bash": {
      "git push*": "deny",
      "az * create *": "deny",
      "az * delete *": "deny",
      "az * update *": "deny",
      "az * start *": "deny",
      "az * stop *": "deny",
      "az * restart *": "deny",
      "az * set-policy *": "deny",
      "az login*": "deny",
      "az logout*": "deny",
      "docker ps*": "allow",
      "docker images*": "allow",
      "docker image ls*": "allow",
      "docker logs *": "allow",
      "docker inspect *": "allow",
      "docker info*": "allow",
      "docker version*": "allow",
      "docker stats*": "allow",
      "docker *": "ask"
    }
  }
}